# Copy backend settings into apps/backend/.env for local development.
# The frontend proxies /api to http://localhost:4100 in Vite.
# For a deployed static frontend, set VITE_API_BASE_URL in the frontend service.

PORT=4100
FRONTEND_ORIGIN=http://localhost:5173
ECI_BASE_URL=https://results.eci.gov.in
ECI_CONSTITUENCY_LIST_URL=https://results.eci.gov.in/ResultAcGenNov2025/statewiseS041.htm
ECI_CANDIDATE_DETAIL_URL_TEMPLATE=https://results.eci.gov.in/ResultAcGenNov2025/candidateswise-S04{constituencyNumber}.htm
# Admin settings password is currently fixed in the backend: ldfudf#2026
ECI_ELECTION_PATH=
ECI_KERALA_STATE_PAGE=
ECI_KERALA_STATE_CODE=
CACHE_TTL_SECONDS=25
DEFAULT_FAVORITES=thrissur,ernakulam,palakkad,nemom
REQUEST_TIMEOUT_MS=12000

# Frontend build-time setting for Render Static Site deployments.
VITE_API_BASE_URL=http://localhost:4100
